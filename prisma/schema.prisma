generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CardCache {
  id        Int      @id @default(autoincrement())
  userSlug  String   @unique
  cardsJson String
  cardCount Int
  fetchedAt DateTime @default(now())
}

model SavedLineup {
  id        Int      @id @default(autoincrement())
  name      String   @default("Default")
  level     Int
  slots     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InSeasonDraft {
  id              Int      @id @default(autoincrement())
  userSlug        String
  forUserSlug     String
  competitionSlug String
  fixtureSlug     String
  payload         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userSlug, forUserSlug, competitionSlug, fixtureSlug])
  @@index([userSlug, fixtureSlug])
}

model Settings {
  id        Int      @id @default(1)
  userSlug  String   @default("ba-zii")
  updatedAt DateTime @updatedAt
}

model StreakHistory {
  id          Int      @id @default(autoincrement())
  level       Int
  threshold   Int
  actualScore Int
  success     Boolean
  reward      String
  playedAt    DateTime @default(now())
}

model game_collector_state {
  game_id      String    @id
  status       String    @default("tracking")
  last_poll_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)
}

model game_events {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  game_id            String
  player_slug        String
  player_name        String
  team_code          String?   @default("")
  minute             Int?      @default(0)
  stat               String
  category           String    @default("all_around")
  points_delta       Float?    @default(0)
  new_value          Float?    @default(0)
  player_total_score Float?    @default(0)
  timestamp          BigInt    @default(0)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)

  @@index([game_id, created_at], map: "idx_game_events_game_id")
  @@index([player_slug], map: "idx_game_events_player")
}

model room_messages {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_id      String
  author       String
  message      String
  message_type String    @default("chat")
  metadata     Json?     @default("{}")
  created_at   DateTime? @default(now()) @db.Timestamptz(6)

  @@index([room_id, created_at], map: "idx_messages_room")
}

model LeaderboardResult {
  id               Int      @id @default(autoincrement())
  fixtureSlug      String
  gameWeek         Int
  leaderboardSlug  String   @unique
  leaderboardName  String
  leagueSlug       String
  leagueName       String
  division         Int
  mainRarityType   String
  totalEntries     Int
  rankingsJson     String
  fetchedAt        DateTime @default(now())

  @@index([gameWeek])
  @@index([gameWeek, division])
  @@index([mainRarityType, gameWeek])
}

model ComputedResults {
  id                    Int      @id @default(autoincrement())
  key                   String   @unique   // "achievements:671", "power-rankings:671", "power-rankings:all"
  dataJson              String              // pre-computed JSON result
  computedAt            DateTime @default(now())

  @@index([key])
}
