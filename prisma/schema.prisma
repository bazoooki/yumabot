// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Settings {
  id        Int      @id @default(1)
  userSlug  String   @default("ba-zii")
  updatedAt DateTime @updatedAt
}

model SavedLineup {
  id        Int      @id @default(autoincrement())
  name      String   @default("Default")
  level     Int
  slots     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CardCache {
  id        Int      @id @default(autoincrement())
  userSlug  String   @unique
  cardsJson String   // Full JSON blob of cards array
  cardCount Int
  fetchedAt DateTime @default(now())
}

model StreakHistory {
  id          Int      @id @default(autoincrement())
  level       Int
  threshold   Int
  actualScore Int
  success     Boolean
  reward      String
  playedAt    DateTime @default(now())
}

model MarketOffer {
  id          Int      @id @default(autoincrement())
  offerId     String   @unique
  playerSlug  String
  playerName  String
  position    String?
  rarity      String
  priceWei    String
  priceEth    Float
  buyerSlug   String?
  sellerSlug  String?
  clubName    String?
  cardSlug    String?
  offerType   String?
  offerStatus String?
  dealStatus  String?
  receivedAt  DateTime @default(now())

  @@index([playerSlug, receivedAt])
  @@index([receivedAt])
  @@index([buyerSlug, receivedAt])
}

model MarketAlert {
  id            Int      @id @default(autoincrement())
  ruleType      String
  severity      String
  playerSlug    String?
  playerName    String?
  title         String
  description   String
  metadata      String   @default("{}")
  acknowledged  Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([playerSlug, createdAt])
}

model OfferLifecycleEvent {
  id               Int      @id @default(autoincrement())
  offerId          String
  playerSlug       String
  playerName       String
  status           String
  priceEth         Float
  previousPriceEth Float?
  sellerSlug       String?
  cardSlug         String?
  receivedAt       DateTime @default(now())

  @@index([playerSlug, receivedAt])
  @@index([receivedAt])
  @@index([offerId])
}

model CardStateEvent {
  id            Int      @id @default(autoincrement())
  cardSlug      String
  playerSlug    String
  playerName    String
  rarity        String
  onSale        Boolean
  inLineup      Boolean
  ownerSlug     String?
  lineupDetails String?
  receivedAt    DateTime @default(now())

  @@index([playerSlug, receivedAt])
  @@index([cardSlug, receivedAt])
  @@index([receivedAt])
}
